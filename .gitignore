# Fuse - Comprehensive .gitignore
# Generated for AI Model Management Platform

# ============================================
# Rust / Cargo
# ============================================
# Build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo lock file (uncomment if building a library)
# Cargo.lock

# Cargo build cache
.cargo/
.cargo-cache/

# ============================================
# IDE / Editor
# ============================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ IDEA / CLion / RustRover
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Zed
.zed/

# ============================================
# Operating System
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================
# Fuse Application Data
# ============================================
# User data directory
.fuse/
!.fuse/specs/
.fuse/models/
.fuse/cache/
.fuse/logs/
.fuse/embeddings/
.fuse/vibe/
.fuse/*.redb
.fuse/*.db
.fuse/*.sqlite
.fuse/*.sqlite3

# Configuration files with sensitive data
config.toml
config.yaml
config.yml
.env
.env.local
.env.*.local
secrets.toml
credentials.toml

# Keep example configs
!config.example.toml
!config.example.yaml

